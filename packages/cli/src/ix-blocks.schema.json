{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Siemens ix Blocks Lockfile",
  "description": "Lockfile for ix blocks CLI tracking installed blocks and file hashes",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON schema reference"
    },
    "targetFolder": {
      "type": "string",
      "description": "Target folder where blocks are installed",
      "default": "src/blocks"
    },
    "blocks": {
      "type": "array",
      "description": "List of installed blocks",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Block name"
          },
          "version": {
            "type": "string",
            "description": "Block version"
          },
          "files": {
            "type": "array",
            "description": "Installed files with content hashes",
            "items": {
              "type": "object",
              "properties": {
                "path": {
                  "type": "string",
                  "description": "Relative file path from project root"
                },
                "hash": {
                  "type": "string",
                  "description": "SHA-256 content hash"
                }
              },
              "required": ["path", "hash"],
              "additionalProperties": false
            }
          }
        },
        "required": ["name", "version"],
        "additionalProperties": false
      },
      "default": []
    }
  },
  "required": ["targetFolder", "blocks"],
  "additionalProperties": false
}
