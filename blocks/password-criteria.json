{
  "$schema": "./../tooling/registry/schemas/block.schema.json",
  "name": "password-criteria",
  "description": "Use this block to show a password input together with live password requirement validation and visual valid or invalid states.",
  "keywords": [
    "password",
    "password criteria",
    "requirements",
    "validation",
    "security",
    "form"
  ],
  "preview": "react-blocks/dist/ix/password-criteria",
  "variants": {
    "react": {
      "files": [
        {
          "target": "react/password-criteria.tsx",
          "source": "react-blocks/src/routes/password-criteria/password-criteria.tsx"
        },
        {
          "target": "react/password-criteria.module.css",
          "source": "react-blocks/src/routes/password-criteria/password-criteria.module.css"
        }
      ],
      "dependencies": [
        {
          "name": "@siemens/ix",
          "version": "^4.0.0"
        },
        {
          "name": "@siemens/ix-icons",
          "version": "^3.3.0"
        },
        {
          "name": "@siemens/ix-react",
          "version": "^4.0.0"
        }
      ]
    },
    "angular": {
      "files": [
        {
          "target": "angular/password-criteria.ts",
          "source": "angular-standalone-blocks/src/routes/password-criteria/password-criteria.ts"
        },
        {
          "target": "angular/password-criteria.html",
          "source": "angular-standalone-blocks/src/routes/password-criteria/password-criteria.html"
        },
        {
          "target": "angular/password-criteria.css",
          "source": "angular-standalone-blocks/src/routes/password-criteria/password-criteria.css"
        }
      ],
      "dependencies": [
        {
          "name": "@siemens/ix",
          "version": "^4.0.0"
        },
        {
          "name": "@siemens/ix-icons",
          "version": "^3.3.0"
        },
        {
          "name": "@siemens/ix-angular",
          "version": "^4.0.0"
        }
      ]
    }
  }
}
