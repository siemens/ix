{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IX Block Definition",
  "description": "Schema for Siemens IX block definition files",
  "type": "object",
  "required": ["name", "variants"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "variants": {
      "type": "object",
      "minProperties": 1,
      "properties": {
        "react": {
          "$ref": "#/definitions/variant"
        },
        "angular": {
          "$ref": "#/definitions/variant"
        },
        "vue": {
          "$ref": "#/definitions/variant"
        }
      },
      "additionalProperties": {
        "$ref": "#/definitions/variant"
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "variant": {
      "type": "object",
      "required": ["files"],
      "properties": {
        "files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["source", "target"],
            "properties": {
              "source": {
                "type": "string"
              },
              "target": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "version"],
            "properties": {
              "name": {
                "type": "string"
              },
              "version": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  }
}
