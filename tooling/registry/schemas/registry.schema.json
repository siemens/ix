{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IX Unified Registry",
  "description": "Registry schema for Siemens IX blocks, examples and component metadata catalog",
  "type": "object",
  "required": ["name", "dist-tags", "versions"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Registry package name",
      "pattern": "^[a-z0-9-]+$"
    },
    "dist-tags": {
      "type": "object",
      "description": "Distribution tags mapping to version numbers",
      "required": ["latest"],
      "properties": {
        "latest": {
          "type": "string",
          "description": "Latest stable version",
          "pattern": "^[a-zA-Z0-9._-]+$"
        }
      },
      "additionalProperties": {
        "type": "string",
        "pattern": "^[a-zA-Z0-9._-]+$"
      }
    },
    "versions": {
      "type": "object",
      "description": "Available versions and their catalog entries",
      "minProperties": 1,
      "patternProperties": {
        "^[a-zA-Z0-9._-]+$": {
          "$ref": "#/definitions/versionEntry"
        }
      },
      "additionalProperties": false
    }
  },
  "definitions": {
    "versionEntry": {
      "type": "object",
      "required": ["blocks", "examples", "components", "searchIndex"],
      "properties": {
        "blocks": {
          "type": "array",
          "description": "List of blocks available in this version",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/blockReference"
          }
        },
        "examples": {
          "type": "array",
          "description": "List of examples available in this version",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/exampleReference"
          }
        },
        "components": {
          "type": "object",
          "required": [
            "componentDoc",
            "componentIndex",
            "componentSearchIndex"
          ],
          "properties": {
            "componentDoc": { "type": "string", "pattern": "\\.json$" },
            "componentIndex": { "type": "string", "pattern": "\\.json$" },
            "componentSearchIndex": {
              "type": "string",
              "pattern": "\\.json$"
            }
          },
          "additionalProperties": false
        },
        "searchIndex": {
          "type": "object",
          "description": "Framework-specific MiniSearch index files for blocks and examples",
          "required": ["blocks", "examples"],
          "properties": {
            "blocks": { "$ref": "#/definitions/frameworkSearchIndex" },
            "examples": { "$ref": "#/definitions/frameworkSearchIndex" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "frameworkSearchIndex": {
      "type": "object",
      "properties": {
        "html": { "type": "string", "pattern": "\\.json$" },
        "react": { "type": "string", "pattern": "\\.json$" },
        "angular": { "type": "string", "pattern": "\\.json$" },
        "angular-standalone": { "type": "string", "pattern": "\\.json$" },
        "vue": { "type": "string", "pattern": "\\.json$" }
      },
      "additionalProperties": false
    },
    "blockReference": {
      "type": "object",
      "required": ["name", "path"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Block identifier",
          "pattern": "^[a-z0-9-]+$"
        },
        "path": {
          "type": "string",
          "description": "Relative path to block configuration file",
          "pattern": "\\.json$"
        }
      },
      "additionalProperties": false
    },
    "exampleReference": {
      "type": "object",
      "required": ["name", "path"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Example identifier",
          "pattern": "^[a-z0-9-]+$"
        },
        "path": {
          "type": "string",
          "description": "Relative path to example configuration file",
          "pattern": "\\.json$"
        }
      },
      "additionalProperties": false
    }
  }
}
